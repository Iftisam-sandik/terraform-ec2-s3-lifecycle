# Terraform local files
.terraform/
.terraform.lock.hcl

# Terraform state files - do not commit
*.tfstate
*.tfstate.*

# Terraform variable files - may contain secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS files
.DS_Store
Thumbs.db
